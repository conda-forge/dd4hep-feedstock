From 1482a62cc77968efca99a5ec10ec8328d888900d Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Fri, 9 Jan 2026 22:15:21 +0100
Subject: [PATCH 3/6] fix: preload libpython when running listcomponents on
 macOS

On macOS, plugins using Python symbols are built with
-undefined dynamic_lookup. When listcomponents loads these plugins,
the Python symbols are unresolved because listcomponents itself
is not linked against Python.

Fix by setting DYLD_INSERT_LIBRARIES to preload libpython when
running listcomponents during the build.
---
 cmake/DD4hep.cmake | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/cmake/DD4hep.cmake b/cmake/DD4hep.cmake
index 8232f8ff..116a1edb 100644
--- a/cmake/DD4hep.cmake
+++ b/cmake/DD4hep.cmake
@@ -98,12 +98,20 @@ function(dd4hep_generate_rootmap library)
   )
   set(rootmapfile ${CMAKE_SHARED_MODULE_PREFIX}${library}.components)
 
+  # On macOS, plugins using Python symbols are built with -undefined dynamic_lookup.
+  # We need to preload libpython so these symbols resolve when listcomponents loads the plugin.
+  set(_preload_env)
+  if(APPLE AND Python_LIBRARIES)
+    set(_preload_env "DYLD_INSERT_LIBRARIES=${Python_LIBRARIES}")
+  endif()
+
   add_custom_command(OUTPUT ${rootmapfile}
                      DEPENDS ${library}
                      VERBATIM COMMAND
                      "${CMAKE_COMMAND}" -E env
                      "${ENV_VAR}=${_ld_path}"
                      "ROOT_LIBRARY_PATH=${DD4HEP_ROOT_LIBRARY_PATH}"
+                     ${_preload_env}
                      $<TARGET_FILE:DD4hep::listcomponents> -o ${rootmapfile} $<TARGET_FILE_NAME:${library}>
                      WORKING_DIRECTORY ${LIBRARY_OUTPUT_PATH}
                      )
